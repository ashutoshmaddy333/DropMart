generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── RBAC Master Tables (roles, rights, mapping) ────────────────────────────

model MasterPermissionGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions MasterPermission[]

  @@map("master_permission_groups")
}

model MasterRole {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  rolePermissions  RolePermission[]

  @@map("master_roles")
}

model MasterPermission {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String?
  groupId     String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group           MasterPermissionGroup @relation(fields: [groupId], references: [id])
  rolePermissions RolePermission[]

  @@map("master_permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  grantedAt    DateTime @default(now())
  grantedBy    String?

  role       MasterRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission MasterPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Other Master Tables ──────────────────────────────────────────────────────

model MasterUserStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("master_user_statuses")
}

model MasterOrderStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  isFinal   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("master_order_statuses")
}

model MasterPaymentMethod {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  icon      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("master_payment_methods")
}

model MasterPaymentStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("master_payment_statuses")
}

model MasterSupplierStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suppliers Supplier[]

  @@map("master_supplier_statuses")
}

model MasterProductStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("master_product_statuses")
}

model MasterDeliveryStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries DeliveryAssignment[]

  @@map("master_delivery_statuses")
}

model MasterCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("master_categories")
}

// ─── Users (linked to master_roles + master_user_statuses) ────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  avatar       String?
  roleId       String
  statusId     String
  lastLoginAt  DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  role         MasterRole       @relation(fields: [roleId], references: [id])
  status       MasterUserStatus @relation(fields: [statusId], references: [id])
  supplier     Supplier?
  deliveryBoy  DeliveryBoy?
  orders       Order[]           @relation("CustomerOrders")
  payments     PaymentTransaction[]
  verifiedSuppliers Supplier[]   @relation("VerifiedBy")
  approvedProducts  Product[]    @relation("ApprovedBy")
  notifications     Notification[]
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Suppliers ──────────────────────────────────────────────────────────────

model Supplier {
  id            String    @id @default(cuid())
  userId        String    @unique
  businessName  String
  warehouseCity String
  gstNumber     String?
  address       String?
  statusId      String
  verifiedAt    DateTime?
  verifiedById  String?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       MasterSupplierStatus @relation(fields: [statusId], references: [id])
  verifiedBy   User?                @relation("VerifiedBy", fields: [verifiedById], references: [id])
  products     Product[]
  orders       Order[]

  @@map("suppliers")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String
  shortDescription String
  brand            String?
  price            Decimal  @db.Decimal(10, 2)
  mrp              Decimal  @db.Decimal(10, 2)
  images           String[]
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  stockCount       Int      @default(0)
  inStock          Boolean  @default(true)
  features         String[]
  specifications   Json?
  warehouseCity    String
  deliveryDays     Int      @default(3)
  isFeatured       Boolean  @default(false)
  isFlashDeal      Boolean  @default(false)
  flashDealEndsAt  DateTime?
  tags             String[]
  supplierId       String
  categoryId       String
  statusId         String
  approvedAt       DateTime?
  approvedById     String?
  rejectionNote    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  category   MasterCategory      @relation(fields: [categoryId], references: [id])
  status     MasterProductStatus @relation(fields: [statusId], references: [id])
  approvedBy User?               @relation("ApprovedBy", fields: [approvedById], references: [id])
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@map("products")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  label     String
  value     String
  inStock   Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  supplierId      String
  statusId        String
  paymentMethodId String
  paymentStatusId String
  subtotal        Decimal  @db.Decimal(10, 2)
  shipping        Decimal  @db.Decimal(10, 2)
  discount        Decimal  @default(0) @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  notes           String?
  trackingId      String?
  warehouseCity   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer      User                @relation("CustomerOrders", fields: [customerId], references: [id])
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  status        MasterOrderStatus   @relation(fields: [statusId], references: [id])
  paymentMethod MasterPaymentMethod @relation(fields: [paymentMethodId], references: [id])
  paymentStatus MasterPaymentStatus @relation(fields: [paymentStatusId], references: [id])
  items         OrderItem[]
  address       OrderAddress?
  delivery      DeliveryAssignment?
  payment       PaymentTransaction?
  statusHistory OrderStatusHistory[]

  @@map("orders")
}

model PaymentTransaction {
  id                String   @id @default(cuid())
  orderId           String   @unique
  customerId        String
  razorpayOrderId   String?  @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  amountPaise       Int
  currency          String   @default("INR")
  method            String
  status            String   @default("created")
  qrCodeId          String?
  qrCodeImageUrl    String?
  webhookEventId    String?  @unique
  failureReason     String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer User  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("payment_transactions")
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String?
  toStatus   String
  source     String
  note       String?
  metadata   Json?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  image     String?
  variant   String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderAddress {
  id      String @id @default(cuid())
  orderId String @unique
  name    String
  phone   String
  line1   String
  line2   String?
  city    String
  state   String
  pincode String
  lat     Float?
  lng     Float?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

// ─── Live Delivery Tracking ───────────────────────────────────────────────────

model DeliveryBoy {
  id        String   @id @default(cuid())
  userId    String   @unique
  vehicleNo String?
  isOnline  Boolean  @default(false)
  currentLat Float?
  currentLng Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments DeliveryAssignment[]

  @@map("delivery_boys")
}

model DeliveryAssignment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  deliveryBoyId String
  statusId      String
  pickupLat     Float?
  pickupLng     Float?
  dropLat       Float?
  dropLng       Float?
  currentLat    Float?
  currentLng    Float?
  estimatedMins Int?
  assignedAt    DateTime @default(now())
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  updatedAt     DateTime @updatedAt

  order       Order                @relation(fields: [orderId], references: [id])
  deliveryBoy DeliveryBoy          @relation(fields: [deliveryBoyId], references: [id])
  status      MasterDeliveryStatus @relation(fields: [statusId], references: [id])
  locations   DeliveryLocation[]

  @@map("delivery_assignments")
}

model DeliveryLocation {
  id           String   @id @default(cuid())
  assignmentId String
  lat          Float
  lng          Float
  heading      Float?
  speed        Float?
  recordedAt   DateTime @default(now())

  assignment DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, recordedAt])
  @@map("delivery_locations")
}

// ─── Platform Settings ────────────────────────────────────────────────────────

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
